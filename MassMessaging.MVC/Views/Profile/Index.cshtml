@{
    ViewData["Title"] = "Profilim";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4 text-center">
                    <div class="mb-4">
                        <i class="fa-solid fa-circle-user fa-5x text-primary"></i>
                    </div>

                    <h4 class="fw-bold" id="userName">Yükleniyor...</h4>
                    <p class="text-muted" id="userEmail"></p>

                    <hr class="my-4">

                    <div class="text-start mt-4">
                        <div class="mb-3">
                            <label class="small text-muted fw-bold text-uppercase">Ad Soyad</label>
                            <input type="text" id="fullNameDisplay" class="form-control" readonly>
                        </div>
                        <div class="mb-3">
                            <label class="small text-muted fw-bold text-uppercase">E-posta</label>
                            <input type="text" id="emailDisplay" class="form-control" readonly>
                        </div>
                    </div>

                    <div class="d-grid gap-2 mt-4">
                        <a href="/Chat/Index" class="btn btn-primary">Sohbetlere Dön</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const API_BASE = "https://localhost:7124/api";
        const token = localStorage.getItem("JWToken");

        document.addEventListener("DOMContentLoaded", async () => {
            if (!token) {
                window.location.href = "/Auth/Login";
                return;
            }
            await loadProfile();
        });

        // Profil verilerini çek ve ekrana bas
        async function loadProfile() {
            try {
                const response = await fetch(`${API_BASE}/User/profile`, {
                    headers: { "Authorization": `Bearer ${token}` }
                });

                if (response.ok) {
                    const user = await response.json();

                    // Verileri yerleştir
                    document.getElementById("userName").innerText = `${user.firstName} ${user.lastName}`;
                    document.getElementById("userEmail").innerText = user.email;
                    document.getElementById("fullNameDisplay").value = `${user.firstName} ${user.lastName}`;
                    document.getElementById("emailDisplay").value = user.email;
                } else {
                    console.error("Profil verisi çekilemedi.");
                }
            } catch (e) {
                console.error("Hata:", e);
                document.getElementById("userName").innerText = "Hata oluştu!";
            }
        }
    </script>
}