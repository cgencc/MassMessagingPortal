@{
    ViewData["Title"] = "Şifremi Unuttum";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card modern-card p-4">
            <div class="text-center mb-4">
                <i class="fa-solid fa-key text-primary fa-3x mb-2"></i>
                <h3 class="fw-bold">Şifremi Unuttum</h3>
                <p class="text-muted small">Sisteme kayıtlı e-posta adresinizi girdiğinizde size bir şifre sıfırlama bağlantısı gönderilecektir.</p>
            </div>

            <div id="alertBox" class="alert d-none" role="alert"></div>

            <div id="forgotForm">
                <div class="mb-3">
                    <label class="form-label fw-semibold">E-posta Adresi</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fa-solid fa-envelope"></i></span>
                        <input type="email" id="emailInput" class="form-control" placeholder="ornek@mail.com" required>
                    </div>
                </div>
                <button onclick="handleForgotPassword()" id="submitBtn" class="btn btn-primary w-100 rounded-pill py-2 fw-bold">
                    Bağlantı Gönder <i class="fa-solid fa-paper-plane ms-1"></i>
                </button>
            </div>

            <div class="text-center mt-4">
                <a href="/Auth/Login" class="text-decoration-none small"><i class="fa-solid fa-arrow-left me-1"></i> Giriş Ekranına Dön</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        async function handleForgotPassword() {
            const email = document.getElementById("emailInput").value.trim();
            const alertBox = document.getElementById("alertBox");
            const submitBtn = document.getElementById("submitBtn");

            if (!email) {
                showAlert("Lütfen e-posta adresinizi girin.", "danger");
                return;
            }

            submitBtn.disabled = true;
            submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> Gönderiliyor...';

            try {
                const res = await fetch("https://localhost:7124/api/Auth/forgot-password", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ email: email })
                });
                const data = await res.json();

                if (res.ok) {
                    showAlert(data.message || "Bağlantı başarıyla oluşturuldu! Lütfen API konsolunu (Visual Studio Output) kontrol edin.", "success");
                    document.getElementById("forgotForm").classList.add("d-none");
                } else {
                    showAlert(data.message || "Bir hata oluştu.", "danger");
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = 'Bağlantı Gönder <i class="fa-solid fa-paper-plane ms-1"></i>';
                }
            } catch (e) {
                showAlert("Sunucuya bağlanılamadı.", "danger");
                submitBtn.disabled = false;
                submitBtn.innerHTML = 'Bağlantı Gönder <i class="fa-solid fa-paper-plane ms-1"></i>';
            }
        }

        function showAlert(msg, type) {
            const alertBox = document.getElementById("alertBox");
            alertBox.className = `alert alert-${type}`;
            alertBox.innerText = msg;
            alertBox.classList.remove("d-none");
        }
    </script>
}