@{
    ViewData["Title"] = "Kayıt Ol";
}

<div class="row justify-content-center mt-5 pt-3">
    <div class="col-md-6 col-lg-5">
        <div class="card modern-card">
            <div class="card-body p-5">
                <div class="text-center mb-4">
                    <div class="bg-success text-white rounded-circle d-inline-flex justify-content-center align-items-center mb-3" style="width: 60px; height: 60px;">
                        <span class="fs-3">✨</span>
                    </div>
                    <h3 class="fw-bold text-dark">Yeni Hesap Oluştur</h3>
                    <p class="text-muted small">Sadece birkaç adımda aramıza katılın</p>
                </div>

                <div id="messageBox" class="alert d-none" style="font-size: 0.9em;"></div>

                <form id="registerForm">
                    <div class="row g-2 mb-3">
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input type="text" id="firstName" class="form-control" placeholder="Ad" required />
                                <label>Ad</label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating">
                                <input type="text" id="lastName" class="form-control" placeholder="Soyad" required />
                                <label>Soyad</label>
                            </div>
                        </div>
                    </div>
                    <div class="form-floating mb-3">
                        <input type="email" id="email" class="form-control" placeholder="E-posta" required />
                        <label>E-posta Adresi</label>
                    </div>
                    <div class="form-floating mb-4">
                        <input type="password" id="password" class="form-control" placeholder="Şifre" required minlength="6" />
                        <label>Şifre (En az 6 karakter)</label>
                    </div>
                    <button type="submit" id="submitBtn" class="btn btn-success w-100 py-3 fw-bold rounded-3 shadow-sm">Kayıt Ol</button>
                </form>

                <div class="text-center mt-4 pt-2 border-top">
                    <p class="mb-0 text-muted small">Zaten hesabınız var mı? <a href="/Auth/Login" class="text-success fw-bold text-decoration-none">Giriş Yapın</a></p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const REGISTER_API_URL = "https://localhost:7124/api/Auth/register";

        document.getElementById("registerForm").addEventListener("submit", async function (e) {
            e.preventDefault();

            const messageBox = document.getElementById("messageBox");
            const submitBtn = document.getElementById("submitBtn");

            submitBtn.disabled = true;
            submitBtn.innerHTML = "Kaydediliyor...";

            const payload = {
                firstName: document.getElementById("firstName").value.trim(),
                lastName: document.getElementById("lastName").value.trim(),
                email: document.getElementById("email").value.trim(),
                password: document.getElementById("password").value
            };

            try {
                const response = await fetch(REGISTER_API_URL, {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify(payload)
                });

                const result = await response.json();
                messageBox.classList.remove("d-none");

                if (response.ok) {
                    messageBox.className = "alert alert-success";
                    messageBox.innerText = "Harika! Kayıt başarılı. Giriş sayfasına yönlendiriliyorsunuz...";
                    setTimeout(() => { window.location.href = "/Auth/Login"; }, 2000);
                } else {
                    messageBox.className = "alert alert-danger";
                    // Identity'den gelen hata listesini (array) birleştirip gösteriyoruz
                    let errorMessage = "Kayıt başarısız: ";
                    if (Array.isArray(result)) {
                        errorMessage += result.map(err => err.description).join(", ");
                    } else if (result.message) {
                        errorMessage += result.message;
                    } else {
                        errorMessage += "Bilgilerinizi kontrol edin.";
                    }
                    messageBox.innerText = errorMessage;
                }
            } catch (error) {
                messageBox.classList.remove("d-none");
                messageBox.className = "alert alert-danger";
                messageBox.innerText = "Sunucuya bağlanılamadı. Lütfen API'nin çalıştığından emin olun.";
            } finally {
                submitBtn.disabled = false;
                submitBtn.innerHTML = "Kayıt Ol";
            }
        });
    </script>
}