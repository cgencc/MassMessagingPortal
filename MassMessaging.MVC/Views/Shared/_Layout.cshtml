<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MassMessaging Portal</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        /* Navbar'a ekstra şıklık */
        .premium-navbar {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(0,0,0,0.05);
        }

        .nav-link {
            font-weight: 500;
            color: #555 !important;
            transition: color 0.3s ease;
        }

            .nav-link:hover {
                color: #0d6efd !important;
            }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light premium-navbar shadow-sm mb-3 sticky-top">
            <div class="container">
                <a class="navbar-brand fw-bold text-primary" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="fa-solid fa-paper-plane me-2"></i>MassPortal
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">

                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Ana Sayfa</a>
                        </li>
                    </ul>

                    <ul class="navbar-nav" id="dynamicNav">
                    </ul>

                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // SİSTEMİN KALBİ: Dumb UI Dynamic Navbar
        document.addEventListener("DOMContentLoaded", function () {
            const token = localStorage.getItem("JWToken");
            const dynamicNav = document.getElementById("dynamicNav");

            if (token) {
                // Token varsa (Giriş Yapılmışsa)
                dynamicNav.innerHTML = `
                    <li class="nav-item me-2">
                        <a class="nav-link text-dark" href="/Chat/Index"><i class="fa-solid fa-comments text-primary me-1"></i> Sohbetler</a>
                    </li>
                    <li class="nav-item me-2">
                        <a class="nav-link text-dark" href="#" onclick="alert('Admin paneli yakında...')"><i class="fa-solid fa-shield-halved text-warning me-1"></i> Yönetim</a>
                    </li>
                    <li class="nav-item">
                        <button onclick="logoutApp()" class="btn btn-outline-danger btn-sm rounded-pill mt-1 px-3 fw-bold">
                            <i class="fa-solid fa-right-from-bracket me-1"></i> Çıkış
                        </button>
                    </li>
                `;
            } else {
                // Token yoksa (Ziyaretçiyse)
                dynamicNav.innerHTML = `
                    <li class="nav-item me-2">
                        <a class="btn btn-light btn-sm rounded-pill mt-1 px-3 fw-bold shadow-sm" href="/Auth/Login">Giriş Yap</a>
                    </li>
                    <li class="nav-item">
                        <a class="btn btn-primary btn-sm rounded-pill mt-1 px-3 fw-bold shadow-sm" href="/Auth/Register">Kayıt Ol</a>
                    </li>
                `;
            }
        });

        function logoutApp() {
            localStorage.removeItem("JWToken");
            window.location.href = "/Auth/Login";
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>