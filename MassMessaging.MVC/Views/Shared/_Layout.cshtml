<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MassPortal</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        .premium-navbar {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(0,0,0,0.05);
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light premium-navbar shadow-sm mb-4 sticky-top">
            <div class="container">
                <a class="navbar-brand fw-bold text-primary" href="/Home/Index">
                    <i class="fa-solid fa-paper-plane me-2"></i>MassPortal
                </a>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link fw-bold text-dark" href="/Home/Index">Ana Sayfa</a>
                        </li>
                    </ul>
                    <ul class="navbar-nav" id="dynamicNav"></ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const token = localStorage.getItem("JWToken");
            const dynamicNav = document.getElementById("dynamicNav");

            if (token) {
                let isAdmin = false;
                try {
                    // JWT Token'ı güvenle çözen saf JS kodu
                    const base64Url = token.split('.')[1];
                    const base64 = base64Url.replace(/-/g, '+').replace(/_/g, '/');
                    const payload = JSON.parse(atob(base64));

                    // Microsoft Identity Rol şeması claim tipini kontrol ediyoruz
                    const roleClaim = payload["http://schemas.microsoft.com/ws/2008/06/identity/claims/role"];

                    if (roleClaim === "Admin" || (Array.isArray(roleClaim) && roleClaim.includes("Admin"))) {
                        isAdmin = true;
                    }
                } catch (e) {
                    console.error("Token deşifre edilemedi", e);
                }

                // Navbar Elemanları Dizişi
                let navHtml = `
                    <li class="nav-item me-2">
                        <a class="nav-link fw-semibold text-dark" href="/Chat/Index"><i class="fa-solid fa-comments text-primary me-1"></i> Sohbetler</a>
                    </li>`;

                // EĞER ADMİNSE YÖNETİM BUTONUNU GÖSTER
                if (isAdmin) {
                    navHtml += `
                        <li class="nav-item me-2">
                            <a class="nav-link fw-semibold text-dark" href="/Admin/Index"><i class="fa-solid fa-shield-halved text-danger me-1"></i> Yönetim Paneli</a>
                        </li>`;
                }

                navHtml += `
                    <li class="nav-item">
                        <button onclick="logoutApp()" class="btn btn-outline-danger btn-sm rounded-pill px-3 fw-bold mt-1">Çıkış</button>
                    </li>`;

                dynamicNav.innerHTML = navHtml;
            } else {
                // Giriş yapılmadıysa
                dynamicNav.innerHTML = `
                    <li class="nav-item me-2"><a class="btn btn-light btn-sm rounded-pill px-3 fw-bold shadow-sm" href="/Auth/Login">Giriş Yap</a></li>
                    <li class="nav-item"><a class="btn btn-primary btn-sm rounded-pill px-3 fw-bold shadow-sm" href="/Auth/Register">Kayıt Ol</a></li>`;
            }
        });

        function logoutApp() {
            localStorage.removeItem("JWToken");
            window.location.href = "/Auth/Login";
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>