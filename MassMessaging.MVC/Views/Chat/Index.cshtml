@{
    ViewData["Title"] = "İletişim Portalı";
}

<style>
    .chat-list-item {
        cursor: pointer;
        padding: 15px;
        border-bottom: 1px solid #eee;
        transition: 0.2s;
    }

        .chat-list-item:hover, .active-chat {
            background-color: #e2e3e5 !important;
            border-left: 5px solid #0d6efd;
        }

    #chatBox {
        display: flex;
        flex-direction: column;
        overflow-y: auto;
        background: #e5ddd5;
        gap: 8px;
        flex-grow: 1;
        padding: 12px;
        height: 60vh;
    }

    .msg-bubble {
        max-width: 70%;
        padding: 8px 12px;
        border-radius: 12px;
        word-break: break-word;
        font-size: 0.92rem;
    }

    .msg-me {
        background-color: #d1e7dd;
        align-self: flex-end;
        border-bottom-right-radius: 2px;
    }

    .msg-other {
        background-color: #ffffff;
        align-self: flex-start;
        border-bottom-left-radius: 2px;
        border: 1px solid #ddd;
    }

    .msg-bubble .msg-sender {
        font-size: 10px;
        color: #555;
        display: block;
        margin-bottom: 2px;
        font-weight: 600;
    }

    .msg-bubble .msg-time {
        font-size: 9px;
        color: #888;
        display: block;
        text-align: right;
        margin-top: 3px;
    }

    #chatEmptyState {
        color: #aaa;
        text-align: center;
        margin: auto;
        font-size: 0.9rem;
    }
</style>

<div class="row g-0 mt-3" style="height: 85vh;">
    <div class="col-md-3 border-end bg-white d-flex flex-column">
        <div class="p-3 border-bottom bg-light fw-bold">
            <i class="fa-solid fa-comments text-primary me-2"></i>Sohbetler
        </div>
        <div id="chatList" style="overflow-y:auto; flex:1;"></div>
    </div>

    <div class="col-md-9 d-flex flex-column bg-white">
        <div id="adminPin" class="alert alert-warning m-0 py-2 px-3" style="display:none; border-radius:0; font-size:0.85rem;"></div>

        <div id="chatHeader" class="p-3 border-bottom bg-light fw-semibold text-muted" style="font-size:0.9rem;">
            <div id="typingStatus" class="px-3 pb-2 bg-light text-success small fw-bold" style="display:none; font-style:italic;"></div>
            Bir sohbet seçin
        </div>

        <div id="chatBox">
            <div id="chatEmptyState">
                <i class="fa-solid fa-comments fa-2x mb-2 d-block"></i>
                Mesajlaşmak için soldaki listeden birini seçin
            </div>
        </div>

        <div class="p-2 border-top bg-light d-flex align-items-center gap-2">
            <input type="file" id="mediaInput" accept="image/*,video/*,.pdf" style="display:none" onchange="handleFileSelect(event)">
            <button class="btn btn-outline-secondary btn-sm" onclick="document.getElementById('mediaInput').click()" title="Dosya ekle">
                <i class="fa-solid fa-paperclip"></i>
            </button>
            <button class="btn btn-outline-secondary btn-sm" onclick="startCamera()" title="Kamera">
                <i class="fa-solid fa-camera"></i>
            </button>
            <input type="text" id="messageInput" class="form-control rounded-pill" placeholder="Bir şeyler yazın..." onkeydown="if(event.key==='Enter') sendMessage()">
            <button onclick="sendMessage()" class="btn btn-primary rounded-pill px-4">
                Gönder <i class="fa-solid fa-paper-plane ms-1"></i>
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script>
        // --- Sabitler ---
        const API_BASE = "https://localhost:7124/api";
        const HUB_URL = "https://localhost:7124/chatHub";
        const token = localStorage.getItem("JWToken");

        // --- Global Değişkenler ---
        let activeId = null;
        let isGroup = false;
        let activeName = "";
        let connection = null;
        let typingTimer;

        // --- Başlatma İşlemleri ---
        if (!token) window.location.href = "/Auth/Login";

        document.addEventListener("DOMContentLoaded", async () => {
            if (token) await initApp();
        });

        async function initApp() {
            connection = new signalR.HubConnectionBuilder()
                .withUrl(HUB_URL, { accessTokenFactory: () => token })
                .withAutomaticReconnect()
                .build();

            // Hub Dinleyicileri
            connection.on("ReceiveMessage", (sId, sName, content) => {
                if (!isGroup && activeId === sId) renderMessage(sName, content, false);
                else showToast(`📩 ${sName}: ${content}`);
            });

            connection.on("ReceiveGroupMessage", (gName, sName, content) => {
                if (isGroup && activeName === gName) renderMessage(sName, content, false);
                else showToast(`👥 [${gName}] ${sName}: ${content}`);
            });

            connection.on("ReceiveAdminMessage", (content) => {
                const pin = document.getElementById("adminPin");
                pin.innerHTML = `<i class='fa-solid fa-bullhorn me-2'></i><strong>Yönetici Duyurusu:</strong> ${content}`;
                pin.style.display = "block";
            });

            connection.on("ReceiveTyping", (id, name, isGroupMsg) => {
                if (isGroupMsg === isGroup && id === activeId) {
                    const statusEl = document.getElementById("typingStatus");
                    statusEl.innerText = `${name} yazıyor...`;
                    statusEl.style.display = "block";
                    clearTimeout(typingTimer);
                    typingTimer = setTimeout(() => { statusEl.style.display = "none"; }, 2000);
                }
            });

            try {
                await connection.start();
                await loadLists();
            } catch (err) { console.error("SignalR hatası:", err); }
        }

        // --- Yazıyor Durumu Tetikleyici ---
        document.getElementById("messageInput").addEventListener("input", () => {
            if (activeId && connection && connection.state === signalR.HubConnectionState.Connected) {
                connection.invoke("SendTypingStatus", activeId, isGroup).catch(console.error);
            }
        });

        // --- Liste Yükleme ---
        async function loadLists() {
            const list = document.getElementById("chatList");
            list.innerHTML = `<div class="text-center p-3"><div class="spinner-border spinner-border-sm text-primary"></div></div>`;

            try {
                const [uRes, gRes] = await Promise.all([
                    fetch(`${API_BASE}/User/list`, { headers: { "Authorization": `Bearer ${token}` } }),
                    fetch(`${API_BASE}/Group/list`, { headers: { "Authorization": `Bearer ${token}` } })
                ]);
                const users = uRes.ok ? await uRes.json() : [];
                const groups = gRes.ok ? await gRes.json() : [];

                list.innerHTML = "";
                if (users.length > 0) {
                    list.innerHTML += `<div class="px-3 pt-3 pb-1 text-uppercase text-muted" style="font-size:10px;font-weight:700;">Kullanıcılar</div>`;
                    users.forEach(u => list.innerHTML += `<div class="chat-list-item" onclick="startChat('${u.id}', false, this, '${escapeHtml(u.fullName)}')">👤 ${escapeHtml(u.fullName)}</div>`);
                }
                if (groups.length > 0) {
                    list.innerHTML += `<div class="px-3 pt-3 pb-1 text-uppercase text-muted" style="font-size:10px;font-weight:700;">Gruplar</div>`;
                    groups.forEach(g => list.innerHTML += `<div class="chat-list-item" onclick="startChat('${g.id}', true, this, '${escapeHtml(g.name)}')">👥 ${escapeHtml(g.name)}</div>`);
                }
            } catch(e) { list.innerHTML = `<div class="p-3 text-danger small">Listeler yüklenemedi.</div>`; }
        }

        // --- Sohbet Başlat ---
        function startChat(id, group, element, name) {
            activeId = id; isGroup = group; activeName = name;
            document.querySelectorAll('.chat-list-item').forEach(el => el.classList.remove('active-chat'));
            if(element) element.classList.add('active-chat');
            document.getElementById("chatHeader").innerText = name;
            loadHistory(id);
        }

        // --- Mesaj Geçmişi ---
        async function loadHistory(id) {
            const chatBox = document.getElementById("chatBox");
            chatBox.innerHTML = '<div class="text-center p-3 text-muted">Yükleniyor...</div>';
            try {
                const res = await fetch(`${API_BASE}/Message/history/${id}`, { headers: { "Authorization": `Bearer ${token}` } });
                const msgs = await res.json();
                chatBox.innerHTML = "";
                msgs.forEach(m => renderMessage(m.senderName, m.content, m.isMine, m.sentDate));
            } catch(e) { chatBox.innerHTML = '<div class="text-center p-3 text-danger">Hata!</div>'; }
        }

        // --- Mesaj Çizim ---
        function renderMessage(name, content, isMine, sentDate = null) {
            const chatBox = document.getElementById("chatBox");
            const empty = document.getElementById("chatEmptyState");
            if (empty) empty.remove();

            const timeStr = new Date().toLocaleTimeString("tr-TR", { hour: "2-digit", minute: "2-digit" });
            chatBox.innerHTML += `
                <div class="msg-bubble ${isMine ? 'msg-me' : 'msg-other'}">
                    <span class="msg-sender">${escapeHtml(name)}</span>
                    ${content}
                    <span class="msg-time">${timeStr}</span>
                </div>`;
            chatBox.scrollTop = chatBox.scrollHeight;
        }

        // --- Mesaj Gönder ---
        async function sendMessage(contentOverride = null) {
            const text = contentOverride || document.getElementById("messageInput").value.trim();
            if(!text || !activeId) return;

            const res = await fetch(`${API_BASE}/Message/send`, {
                method: "POST",
                headers: { "Content-Type": "application/json", "Authorization": `Bearer ${token}` },
                body: JSON.stringify({ content: text, [isGroup ? 'groupId' : 'receiverId']: isGroup ? parseInt(activeId) : activeId })
            });

            if(res.ok) {
                renderMessage("Ben", text, true);
                if(!contentOverride) document.getElementById("messageInput").value = "";
            }
        }

        // --- Dosya Yükleme ---
        async function handleFileSelect(e) {
            const file = e.target.files[0];
            const formData = new FormData(); formData.append("file", file);
            const res = await fetch(`${API_BASE}/Message/upload-file`, { method: "POST", headers: { "Authorization": `Bearer ${token}` }, body: formData });
            const data = await res.json();
            sendMessage(`<img src="https://localhost:7124${data.url}" style="max-width:200px; border-radius:8px;">`);
        }

        function startCamera() { alert("Kamera özelliği geliştiriliyor!"); }

        // --- Yardımcılar ---
        function escapeHtml(str) { return String(str).replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;"); }
        function showToast(msg) {
            const toast = document.createElement("div");
            toast.style.cssText = "position:fixed; bottom:20px; right:20px; background:#333; color:#fff; padding:10px 16px; border-radius:8px;";
            toast.textContent = msg;
            document.body.appendChild(toast);
            setTimeout(() => toast.remove(), 3000);
        }
    </script>
}