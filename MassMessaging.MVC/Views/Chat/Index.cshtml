@{
    ViewData["Title"] = "İletişim Portalı";
}

<style>
    .chat-list-item {
        cursor: pointer;
        padding: 15px;
        border-bottom: 1px solid #eee;
        transition: 0.3s;
    }

        .chat-list-item:hover, .active-chat {
            background-color: #e2e3e5 !important;
            border-left: 5px solid #0d6efd;
        }

    .msg-me {
        background-color: #d1e7dd;
        align-self: flex-end;
    }

    .msg-other {
        background-color: #ffffff;
        align-self: flex-start;
    }
</style>

<div class="row g-0 mt-3" style="height: 85vh;">
    <div class="col-md-3 border-end bg-white">
        <div class="p-3 border-bottom bg-light fw-bold">Sohbetler</div>
        <div id="chatList" style="overflow-y:auto; height:100%;"></div>
    </div>

    <div class="col-md-9 d-flex flex-column bg-white">
        <div id="adminPin" class="alert alert-warning m-0" style="display:none; border-radius:0;"></div>
        <div id="chatBox" class="flex-grow-1 p-3 d-flex flex-column" style="overflow-y:auto; background: #e5ddd5; gap: 10px;"></div>

        <div class="p-2 border-top bg-light d-flex align-items-center">
            <input type="file" id="mediaInput" accept="image/*,video/*" style="display:none" onchange="handleFileSelect(event)">
            <button class="btn btn-outline-secondary btn-sm" onclick="document.getElementById('mediaInput').click()">📎</button>
            <button class="btn btn-outline-secondary btn-sm ms-2" onclick="startCamera()">📷</button>

            <input type="text" id="messageInput" class="form-control mx-2 rounded-pill" placeholder="Bir şeyler yazın...">
            <button onclick="sendMessage()" class="btn btn-primary rounded-pill">Gönder 🚀</button>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script>
        const API_BASE = "https://localhost:7124/api";
        const token = localStorage.getItem("JWToken");
        let activeId = null; let isGroup = false;

        document.addEventListener("DOMContentLoaded", loadLists);

        async function loadLists() {
            const list = document.getElementById("chatList");
            const [uRes, gRes] = await Promise.all([
                fetch(`${API_BASE}/User/list`, { headers: { "Authorization": `Bearer ${token}` }}),
                fetch(`${API_BASE}/Group/list`, { headers: { "Authorization": `Bearer ${token}` }})
            ]);
            const users = await uRes.json();
            const groups = await gRes.json();
            list.innerHTML = "";
            users.forEach(u => list.innerHTML += `<div class="chat-list-item" onclick="startChat('${u.id}', false, this)">👤 ${u.fullName}</div>`);
            groups.forEach(g => list.innerHTML += `<div class="chat-list-item" onclick="startChat('${g.id}', true, this)">👥 ${g.name}</div>`);
        }

        function startChat(id, group, element) {
            activeId = id; isGroup = group;
            document.querySelectorAll('.chat-list-item').forEach(el => el.classList.remove('active-chat'));
            element.classList.add('active-chat');
            loadHistory(id);
        }

        async function loadHistory(id) {
            const chatBox = document.getElementById("chatBox");
            chatBox.innerHTML = '<div class="text-center text-muted">Yükleniyor...</div>';
            const res = await fetch(`${API_BASE}/Message/history/${id}`, { headers: { "Authorization": `Bearer ${token}` }});
            const msgs = await res.json();
            chatBox.innerHTML = "";
            msgs.forEach(m => renderMessage(m.senderName, m.content, m.isMine));
        }

        function renderMessage(name, content, isMine) {
            const chatBox = document.getElementById("chatBox");
            chatBox.innerHTML += `<div class="p-2 rounded ${isMine ? 'msg-me' : 'msg-other'}" style="max-width:70%; border:1px solid #ccc;">
                <small style="display:block; font-size:10px; color:#555;">${name}</small>${content}</div>`;
            chatBox.scrollTop = chatBox.scrollHeight;
        }

        async function sendMessage(content = null) {
            const text = content || document.getElementById("messageInput").value;
            if(!text || !activeId) return;

            const payload = {
                content: text,
                [isGroup ? 'groupId' : 'receiverId']: isGroup ? parseInt(activeId) : activeId
            };

            const res = await fetch(`${API_BASE}/Message/send`, {
                method: "POST",
                headers: { "Content-Type": "application/json", "Authorization": `Bearer ${token}` },
                body: JSON.stringify(payload)
            });

            if(res.ok) {
                renderMessage("Ben", text, true);
                if(!content) document.getElementById("messageInput").value = "";
            }
        }

        async function handleFileSelect(e) {
            const formData = new FormData();
            formData.append("file", e.target.files[0]);
            // TOKEN EKLEDİK:
            const res = await fetch(`${API_BASE}/Message/upload-file`, {
                method: "POST",
                headers: { "Authorization": `Bearer ${token}` },
                body: formData
            });
            const data = await res.json();
            sendMessage(`<img src="${data.url}" style="max-width:150px;">`);
        }

        async function startCamera() {
            try {
                const stream = await navigator.mediaDevices.getUserMedia({ video: true });
                const video = document.createElement("video");
                video.srcObject = stream;
                video.play();
                alert("Kamera hazır! (Snapshot için video elementini ekrana gömmelisin)");
            } catch(e) { alert("Kamera izni reddedildi!"); }
        }
    </script>
}