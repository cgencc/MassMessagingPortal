@{
    ViewData["Title"] = "Yönetim Paneli";
}

<style>
    .chat-list-item {
        cursor: pointer;
        padding: 15px;
        border-bottom: 1px solid #eee;
        transition: 0.2s;
    }

        .chat-list-item:hover, .active-chat {
            background-color: #e2e3e5 !important;
            border-left: 5px solid #0d6efd;
        }

    #chatBox {
        display: flex;
        flex-direction: column;
        overflow-y: auto;
        background: #e5ddd5;
        gap: 8px;
        flex-grow: 1;
        padding: 12px;
    }

    .msg-bubble {
        max-width: 70%;
        padding: 8px 12px;
        border-radius: 12px;
        word-break: break-word;
        font-size: 0.92rem;
    }

    .msg-me {
        background-color: #d1e7dd;
        align-self: flex-end;
        border-bottom-right-radius: 2px;
    }

    .msg-other {
        background-color: #ffffff;
        align-self: flex-start;
        border-bottom-left-radius: 2px;
        border: 1px solid #ddd;
    }
</style>

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-lg-10 offset-lg-1">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body p-4 d-flex justify-content-between align-items-center">
                    <div>
                        <h3 class="fw-bold mb-1 text-primary">Sistem Yönetim Paneli</h3>
                        <p class="text-muted mb-0">Kullanıcılar ve gruplar üzerinde tam yetki.</p>
                    </div>
                    <span class="badge bg-danger p-2 px-3 rounded-pill">
                        <i class="fa-solid fa-shield-halved me-1"></i> Admin Yetkisi Aktif
                    </span>
                </div>
            </div>

            <div class="card modern-card shadow-sm border-0">
                <div class="card-header bg-white border-bottom-0 pt-4">
                    <ul class="nav nav-pills" id="adminTabs" role="tablist">
                        <li class="nav-item"><button class="nav-link active rounded-pill px-4" data-bs-toggle="tab" data-bs-target="#users" type="button"><i class="fa-solid fa-users me-2"></i>Kullanıcılar</button></li>
                        <li class="nav-item"><button class="nav-link rounded-pill px-4 ms-2" data-bs-toggle="tab" data-bs-target="#groups" type="button"><i class="fa-solid fa-layer-group me-2"></i>Grup Yönetimi</button></li>
                    </ul>
                </div>

                <div class="card-body p-4">
                    <div class="tab-content" id="adminTabsContent">
                        <div class="tab-pane fade show active" id="users" role="tabpanel">
                            <div class="d-flex justify-content-between align-items-center mb-3 bg-light p-3 rounded">
                                <h6 class="fw-bold mb-0">Kullanıcı Listesi</h6>
                                <div class="input-group w-auto">
                                    <select id="bulkGroupSelect" class="form-select form-select-sm"></select>
                                    <button class="btn btn-sm btn-success" onclick="bulkAddUsers()">Seçilenleri Ekle</button>
                                </div>
                            </div>
                            <div class="table-responsive">
                                <table class="table table-hover align-middle">
                                    <thead class="text-uppercase text-muted small">
                                        <tr>
                                            <th><input type="checkbox" id="selectAll" onclick="toggleSelectAll()"></th>
                                            <th>Ad Soyad</th>
                                            <th>E-posta Adresi</th>
                                            <th class="text-center">Roller</th>
                                            <th class="text-center">İşlemler</th>
                                        </tr>
                                    </thead>
                                    <tbody id="usersTableBody">
                                        <tr><td colspan="5" class="text-center p-4"><div class="spinner-grow text-primary"></div></td></tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <div class="tab-pane fade" id="groups" role="tabpanel">
                            <div class="row">
                                <div class="col-md-5">
                                    <div class="bg-light p-4 rounded-3 border">
                                        <h6 class="fw-bold text-dark mb-3">Yeni Grup Oluştur</h6>
                                        <div class="input-group">
                                            <input type="text" id="newGroupName" class="form-control" placeholder="Grup ismi girin...">
                                            <button onclick="createGroup()" class="btn btn-primary px-3">Ekle</button>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-7">
                                    <h6 class="fw-bold text-dark mb-3">Sistemdeki Gruplar</h6>
                                    <ul id="groupListUI" class="list-group list-group-flush border rounded-3"></ul>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const API_BASE = "https://localhost:7124/api";
        const token = localStorage.getItem("JWToken");

        document.addEventListener("DOMContentLoaded", () => {
            if(!token) { window.location.href = "/Auth/Login"; return; }
            loadUsers();
            loadGroups();
        });

        function toggleSelectAll() {
            const isChecked = document.getElementById("selectAll").checked;
            document.querySelectorAll(".user-checkbox").forEach(cb => cb.checked = isChecked);
        }

        async function bulkAddUsers() {
            const groupId = document.getElementById("bulkGroupSelect").value;
            const selected = Array.from(document.querySelectorAll(".user-checkbox:checked")).map(cb => cb.value);

            if(!groupId) return alert("Lütfen bir grup seçin!");
            if(selected.length === 0) return alert("Lütfen en az bir kullanıcı seçin!");

            const res = await fetch(`${API_BASE}/Group/add-users-bulk`, {
                method: "POST",
                headers: { "Content-Type": "application/json", "Authorization": `Bearer ${token}` },
                body: JSON.stringify({ groupId: parseInt(groupId), userIds: selected })
            });

            if(res.ok) { alert("Kullanıcılar başarıyla eklendi."); }
            else { alert("Hata oluştu."); }
        }

        async function loadUsers() {
            const res = await fetch(`${API_BASE}/Admin/users`, { headers: { "Authorization": `Bearer ${token}` }});
            if (res.ok) {
                const users = await res.json();
                document.getElementById("usersTableBody").innerHTML = users.map(u => `
                    <tr>
                        <td><input type="checkbox" class="user-checkbox" value="${u.id}"></td>
                        <td><div class="fw-bold">${u.firstName} ${u.lastName}</div></td>
                        <td class="text-muted">${u.email}</td>
                        <td class="text-center">${u.roles.map(r => `<span class="badge bg-primary rounded-pill mx-1">${r}</span>`).join('')}</td>
                        <td class="text-center">
                            <button class="btn btn-sm btn-outline-warning" onclick="grantAdmin('${u.id}')"><i class="fa-solid fa-shield"></i></button>
                            <button class="btn btn-sm btn-outline-danger" onclick="deleteUser('${u.id}')"><i class="fa-solid fa-trash"></i></button>
                        </td>
                    </tr>`).join('');
            }
        }

        async function loadGroups() {
            const res = await fetch(`${API_BASE}/Group/list`, { headers: { "Authorization": `Bearer ${token}` }});
            if (res.ok) {
                const groups = await res.json();
                document.getElementById("groupListUI").innerHTML = groups.map(g => `<li class="list-group-item d-flex justify-content-between">${g.name} <span class="badge bg-dark">ID: ${g.id}</span></li>`).join('');
                document.getElementById("bulkGroupSelect").innerHTML = '<option value="">Grup Seçin...</option>' + groups.map(g => `<option value="${g.id}">${g.name}</option>`).join('');
            }
        }

        async function createGroup() {
            const name = document.getElementById("newGroupName").value;
            if(!name) return alert("İsim girin");
            const res = await fetch(`${API_BASE}/Group/create`, {
                method: "POST",
                headers: { "Content-Type": "application/json", "Authorization": `Bearer ${token}` },
                body: JSON.stringify({ name })
            });
            if(res.ok) { alert("Grup oluşturuldu"); loadGroups(); }
        }

        async function grantAdmin(id) { await fetch(`${API_BASE}/Admin/assign-role/${id}/Admin`, { method: "POST", headers: { "Authorization": `Bearer ${token}` }}); loadUsers(); }
        async function deleteUser(id) { await fetch(`${API_BASE}/Admin/delete-user/${id}`, { method: "DELETE", headers: { "Authorization": `Bearer ${token}` }}); loadUsers(); }
    </script>
}