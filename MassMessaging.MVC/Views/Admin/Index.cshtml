@{
    ViewData["Title"] = "Yönetim Paneli";
}

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-lg-10 offset-lg-1">

            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body p-4 d-flex justify-content-between align-items-center">
                    <div>
                        <h3 class="fw-bold mb-1 text-primary">Sistem Yönetim Paneli</h3>
                        <p class="text-muted mb-0">Kullanıcılar ve gruplar üzerinde tam yetki.</p>
                    </div>
                    <span class="badge bg-danger p-2 px-3 rounded-pill">
                        <i class="fa-solid fa-shield-halved me-1"></i> Admin Yetkisi Aktif
                    </span>
                </div>
            </div>

            <div class="card shadow-sm border-0">
                <div class="card-header bg-white border-bottom-0 pt-4">
                    <ul class="nav nav-pills" role="tablist">
                        <li class="nav-item">
                            <button class="nav-link active rounded-pill px-4" data-bs-toggle="tab" data-bs-target="#users" type="button">
                                <i class="fa-solid fa-users me-2"></i>Kullanıcılar
                            </button>
                        </li>
                        <li class="nav-item">
                            <button class="nav-link rounded-pill px-4 ms-2" data-bs-toggle="tab" data-bs-target="#groups" type="button">
                                <i class="fa-solid fa-layer-group me-2"></i>Grup Yönetimi
                            </button>
                        </li>
                    </ul>
                </div>

                <div class="card-body p-4">
                    <div class="tab-content">
                        <div class="tab-pane fade show active" id="users" role="tabpanel">

                            <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3 bg-light p-3 rounded">
                                <div class="d-flex align-items-center gap-2">
                                    <h6 class="fw-bold mb-0">Kullanıcı Listesi</h6>
                                    <div class="input-group input-group-sm" style="width:240px;">
                                        <span class="input-group-text bg-white border-end-0">
                                            <i class="fa-solid fa-magnifying-glass text-muted"></i>
                                        </span>
                                        <input type="text" id="userSearchInput" class="form-control border-start-0"
                                               placeholder="Ad, soyad veya e-posta ara..."
                                               oninput="filterUsers()">
                                    </div>
                                </div>
                                <div class="input-group w-auto">
                                    <select id="bulkGroupSelect" class="form-select form-select-sm"></select>
                                    <button class="btn btn-sm btn-success" onclick="bulkAddUsers()">
                                        <i class="fa-solid fa-plus me-1"></i> Gruba Ekle
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger" onclick="bulkRemoveUsers()">
                                        <i class="fa-solid fa-minus me-1"></i> Gruptan Çıkar
                                    </button>
                                </div>
                            </div>

                            <div class="table-responsive">
                                <table class="table table-hover align-middle">
                                    <thead class="text-uppercase text-muted small">
                                        <tr>
                                            <th><input type="checkbox" id="selectAll" onclick="toggleSelectAll()"></th>
                                            <th>Ad Soyad</th>
                                            <th>E-posta</th>
                                            <th class="text-center">Roller</th>
                                            <th class="text-center">İşlemler</th>
                                        </tr>
                                    </thead>
                                    <tbody id="usersTableBody">
                                        <tr>
                                            <td colspan="5" class="text-center p-4">
                                                <div class="spinner-grow text-primary"></div>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                                <div id="noResultsRow" class="text-center text-muted py-3 d-none">
                                    <i class="fa-solid fa-circle-info me-1"></i> Arama kriterine uyan kullanıcı bulunamadı.
                                </div>
                            </div>
                        </div>
                        <div class="tab-pane fade" id="groups" role="tabpanel">
                            <div class="row">
                                <div class="col-md-5">
                                    <div class="bg-light p-4 rounded-3 border">
                                        <h6 class="fw-bold text-dark mb-3">Yeni Grup Oluştur</h6>
                                        <div class="input-group">
                                            <input type="text" id="newGroupName" class="form-control" placeholder="Grup ismi girin...">
                                            <button onclick="createGroup()" class="btn btn-primary px-3">Ekle</button>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-7">
                                    <h6 class="fw-bold text-dark mb-3">Sistemdeki Gruplar</h6>
                                    <ul id="groupListUI" class="list-group list-group-flush border rounded-3"></ul>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const API_BASE = "https://localhost:7124/api";


        const token = localStorage.getItem("JWToken");

        (function guardAdminPage() {
            if (!token) {
                window.location.href = "/Auth/Login";
                return;
            }
            try {
                const payload = JSON.parse(atob(token.split('.')[1]));

                if (payload.exp && Date.now() / 1000 > payload.exp) {
                    localStorage.removeItem("JWToken");
                    window.location.href = "/Auth/Login";
                    return;
                }

                const role = payload["http://schemas.microsoft.com/ws/2008/06/identity/claims/role"] || payload["role"];
                const isAdmin = role === "Admin" || (Array.isArray(role) && role.includes("Admin"));

                if (!isAdmin) {
                    alert("Bu sayfaya erişim yetkiniz yok.");
                    window.location.href = "/Chat/Index";
                }
            } catch {
                localStorage.removeItem("JWToken");
                window.location.href = "/Auth/Login";
            }
        })();

        const authHeader = () => ({ "Authorization": `Bearer ${token}` });
        const jsonHeader = () => ({ "Content-Type": "application/json", "Authorization": `Bearer ${token}` });

        function toggleSelectAll() {
            const checked = document.getElementById("selectAll").checked;
            document.querySelectorAll("#usersTableBody tr:not([style*='display: none']) .user-checkbox")
                .forEach(cb => cb.checked = checked);
        }
        function filterUsers() {
            const query = document.getElementById("userSearchInput").value.toLowerCase().trim();
            const rows = document.querySelectorAll("#usersTableBody tr");
            let visibleCount = 0;

            rows.forEach(row => {
                const name = (row.dataset.name || "").toLowerCase();
                const email = (row.dataset.email || "").toLowerCase();

                if (!query || name.includes(query) || email.includes(query)) {
                    row.style.display = "";
                    visibleCount++;
                } else {
                    row.style.display = "none";
                }
            });

            document.getElementById("noResultsRow").classList.toggle("d-none", visibleCount > 0);

            document.getElementById("selectAll").checked = false;
        }

        async function bulkAddUsers() {
            const groupId = document.getElementById("bulkGroupSelect").value;
            const selected = Array.from(document.querySelectorAll(".user-checkbox:checked")).map(cb => cb.value);

            if (!groupId) return alert("Lütfen bir grup seçin!");
            if (selected.length === 0) return alert("Lütfen en az bir kullanıcı seçin!");

            const res = await fetch(`${API_BASE}/Group/add-users-bulk`, {
                method: "POST",
                headers: jsonHeader(),
                body: JSON.stringify({ groupId: parseInt(groupId), userIds: selected })
            });

            if (res.ok) {
                alert("Kullanıcılar başarıyla gruba eklendi.");
            } else {
                alert("Gruba ekleme sırasında hata oluştu.");
            }
        }

        async function bulkRemoveUsers() {
            const groupId = document.getElementById("bulkGroupSelect").value;
            const selected = Array.from(document.querySelectorAll(".user-checkbox:checked")).map(cb => cb.value);

            if (!groupId) return alert("Lütfen işlem yapılacak grubu seçin!");
            if (selected.length === 0) return alert("Lütfen gruptan çıkarmak istediğiniz kullanıcıları seçin!");
            if (!confirm("Seçili kullanıcıları bu gruptan çıkarmak istediğinize emin misiniz?")) return;

            let successCount = 0;
            for (let userId of selected) {
                const res = await fetch(`${API_BASE}/Admin/remove-member/${groupId}/${userId}`, {
                    method: "DELETE",
                    headers: authHeader()
                });
                if (res.ok) successCount++;
            }

            alert(`${successCount} kullanıcı gruptan başarıyla çıkarıldı.`);
        }

        async function loadUsers() {
            const res = await fetch(`${API_BASE}/Admin/users`, { headers: authHeader() });

            if (res.status === 401 || res.status === 403) {
                alert("Oturumunuz sona erdi veya yetkiniz yok.");
                window.location.href = "/Auth/Login";
                return;
            }

            const users = await res.json();

            document.getElementById("usersTableBody").innerHTML = users.map(u => {
                const isAdmin = u.roles.includes("Admin");
                return `
                <tr data-name="${(u.firstName + ' ' + u.lastName).toLowerCase()}" data-email="${(u.email || '').toLowerCase()}">
                    <td><input type="checkbox" class="user-checkbox" value="${u.id}"></td>
                    <td><div class="fw-bold">${u.firstName} ${u.lastName}</div></td>
                    <td class="text-muted small">${u.email}</td>
                    <td class="text-center">
                        ${u.roles.map(r => `<span class="badge bg-primary rounded-pill mx-1">${r}</span>`).join('') || '<span class="text-muted small">-</span>'}
                    </td>
                    <td class="text-center d-flex gap-1 justify-content-center">
                        ${!isAdmin
                            ? `<button class="btn btn-sm btn-outline-warning" onclick="grantAdmin('${u.id}')" title="Admin Yap">
                                   <i class="fa-solid fa-shield"></i> Admin Yap
                               </button>`
                            : `<button class="btn btn-sm btn-outline-secondary" onclick="removeAdmin('${u.id}')" title="Admin Yetkisini Al">
                                   <i class="fa-solid fa-shield-xmark"></i> Yetkiyi Al
                               </button>`
                        }
                        <button class="btn btn-sm btn-outline-danger" onclick="deleteUser('${u.id}')" title="Kullanıcıyı Sil">
                            <i class="fa-solid fa-trash"></i>
                        </button>
                    </td>
                </tr>`;
            }).join('');

            filterUsers();
        }

        async function grantAdmin(id) {
            if (!confirm("Bu kullanıcıyı Admin yapmak istediğinize emin misiniz?")) return;

            const res = await fetch(`${API_BASE}/Admin/assign-role/${id}/Admin`, {
                method: "POST",
                headers: authHeader()
            });

            if (res.ok) {
                loadUsers();
            } else {
                alert("Rol atama başarısız.");
            }
        }

        async function removeAdmin(id) {
            if (!confirm("Bu kullanıcının Admin yetkisini kaldırmak istediğinize emin misiniz?")) return;

            const res = await fetch(`${API_BASE}/Admin/remove-role/${id}/Admin`, {
                method: "POST",
                headers: authHeader()
            });

            if (res.ok) {
                loadUsers();
            } else {
                const err = await res.json().catch(() => ({}));
                alert(err.message || "Yetki kaldırma başarısız.");
            }
        }

        async function deleteUser(id) {
            if (!confirm("Bu kullanıcıyı kalıcı olarak silmek istediğinize emin misiniz?")) return;

            const res = await fetch(`${API_BASE}/Admin/delete-user/${id}`, {
                method: "DELETE",
                headers: authHeader()
            });

            if (res.ok) {
                loadUsers();
            } else {
                alert("Silme işlemi başarısız.");
            }
        }

        async function loadGroups() {
            const res = await fetch(`${API_BASE}/Group/list`, {
                headers: authHeader()
            });

            if (!res.ok) return;

            const groups = await res.json();

            document.getElementById("groupListUI").innerHTML = groups.length
                ? groups.map(g => `
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        ${g.name}
                        <div>
                            <span class="badge bg-dark me-2">ID: ${g.id}</span>
                            <button class="btn btn-sm btn-outline-danger" onclick="deleteGroup(${g.id})" title="Grubu Sil">
                                <i class="fa-solid fa-trash"></i>
                            </button>
                        </div>
                    </li>`).join('')
                : '<li class="list-group-item text-muted">Henüz grup yok.</li>';

            document.getElementById("bulkGroupSelect").innerHTML =
                '<option value="">Grup Seçin...</option>' +
                groups.map(g => `<option value="${g.id}">${g.name}</option>`).join('');
        }


        async function createGroup() {
            const name = document.getElementById("newGroupName").value.trim();

            if (!name) return alert("Lütfen bir grup adı girin.");

            const res = await fetch(`${API_BASE}/Group/create`, {
                method: "POST",
                headers: jsonHeader(),
                body: JSON.stringify({ name })
            });

            if (res.ok) {
                document.getElementById("newGroupName").value = "";
                loadGroups();
            } else {
                alert("Grup oluşturulamadı.");
            }
        }


        async function deleteGroup(id) {
            if (!confirm("Bu grubu kalıcı olarak silmek istediğinize emin misiniz?")) return;

            const res = await fetch(`${API_BASE}/Admin/delete-group/${id}`, {
                method: "DELETE",
                headers: authHeader()
            });

            if (res.ok) {
                loadGroups();
            } else {
                const err = await res.json().catch(() => ({}));
                alert(err.message || "Silme işlemi başarısız.");
            }
        }


        document.addEventListener("DOMContentLoaded", () => {
            loadUsers();
            loadGroups();
        });
    </script>
}
