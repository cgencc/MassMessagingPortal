@{
    ViewData["Title"] = "Yönetim Paneli";
}

<style>
    .chat-list-item {
        cursor: pointer;
        padding: 15px;
        border-bottom: 1px solid #eee;
        transition: 0.2s;
    }

        .chat-list-item:hover, .active-chat {
            background-color: #e2e3e5 !important;
            border-left: 5px solid #0d6efd;
        }

    #chatBox {
        display: flex;
        flex-direction: column;
        overflow-y: auto;
        background: #e5ddd5;
        gap: 8px;
        flex-grow: 1;
        padding: 12px;
    }

    .msg-bubble {
        max-width: 70%;
        padding: 8px 12px;
        border-radius: 12px;
        word-break: break-word;
        font-size: 0.92rem;
    }

    .msg-me {
        background-color: #d1e7dd;
        align-self: flex-end;
        border-bottom-right-radius: 2px;
    }

    .msg-other {
        background-color: #ffffff;
        align-self: flex-start;
        border-bottom-left-radius: 2px;
        border: 1px solid #ddd;
    }

    .msg-bubble .msg-sender {
        font-size: 10px;
        color: #555;
        display: block;
        margin-bottom: 2px;
        font-weight: 600;
    }

    .msg-bubble .msg-time {
        font-size: 9px;
        color: #888;
        display: block;
        text-align: right;
        margin-top: 3px;
    }

    #chatEmptyState {
        color: #aaa;
        text-align: center;
        margin: auto;
        font-size: 0.9rem;
    }
</style>

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-lg-10 offset-lg-1">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body p-4 d-flex justify-content-between align-items-center">
                    <div>
                        <h3 class="fw-bold mb-1 text-primary">Sistem Yönetim Paneli</h3>
                        <p class="text-muted mb-0">Kullanıcılar ve gruplar üzerinde tam yetki.</p>
                    </div>
                    <span class="badge bg-danger p-2 px-3 rounded-pill">
                        <i class="fa-solid fa-shield-halved me-1"></i> Admin Yetkisi Aktif
                    </span>
                </div>
            </div>

            <div class="card modern-card shadow-sm border-0">
                <div class="card-header bg-white border-bottom-0 pt-4">
                    <ul class="nav nav-pills" id="adminTabs" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link active rounded-pill px-4" id="users-tab" data-bs-toggle="tab" data-bs-target="#users" type="button" role="tab">
                                <i class="fa-solid fa-users me-2"></i>Kullanıcılar
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link rounded-pill px-4 ms-2" id="groups-tab" data-bs-toggle="tab" data-bs-target="#groups" type="button" role="tab">
                                <i class="fa-solid fa-layer-group me-2"></i>Grup Yönetimi
                            </button>
                        </li>
                    </ul>
                </div>

                <div class="card-body p-4">
                    <div class="tab-content" id="adminTabsContent">
                        <div class="tab-pane fade show active" id="users" role="tabpanel">
                            <div class="table-responsive">
                                <table class="table table-hover align-middle">
                                    <thead class="text-uppercase text-muted small">
                                        <tr>
                                            <th>Ad Soyad</th>
                                            <th>E-posta Adresi</th>
                                            <th class="text-center">Durum</th>
                                            <th class="text-center">İşlemler</th>
                                        </tr>
                                    </thead>
                                    <tbody id="usersTableBody">
                                        <tr><td colspan="4" class="text-center p-4"><div class="spinner-grow text-primary"></div></td></tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <div class="tab-pane fade" id="groups" role="tabpanel">
                            <div class="row">
                                <div class="col-md-5">
                                    <div class="bg-light p-4 rounded-3">
                                        <h6 class="fw-bold text-dark mb-3">Yeni Grup Oluştur</h6>
                                        <div class="input-group">
                                            <input type="text" id="newGroupName" class="form-control" placeholder="Grup ismi girin...">
                                            <button onclick="createGroup()" class="btn btn-primary px-3">Ekle</button>
                                        </div>
                                        <div id="groupResult" class="mt-2 small fw-bold"></div>
                                    </div>
                                </div>
                                <div class="col-md-7">
                                    <h6 class="fw-bold text-dark mb-3">Sistemdeki Gruplar</h6>
                                    <ul id="groupListUI" class="list-group list-group-flush border rounded-3">
                                        <li class="list-group-item text-muted text-center p-3">Yükleniyor...</li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const API_BASE = "https://localhost:7124/api";
        const token = localStorage.getItem("JWToken");

        document.addEventListener("DOMContentLoaded", () => {
            if(!token) { window.location.href = "/Auth/Login"; return; }

            // Admin Yetki Kontrolü
            try {
                const base64Url = token.split('.')[1];
                const base64 = base64Url.replace(/-/g, '+').replace(/_/g, '/');
                const jsonPayload = decodeURIComponent(window.atob(base64).split('').map(function(c) {
                    return '%' + ('00' + c.charCodeAt(0).toString(16)).slice(-2);
                }).join(''));

                const payload = JSON.parse(jsonPayload);
                const roleClaim = payload["http://schemas.microsoft.com/ws/2008/06/identity/claims/role"] || payload["role"];

                if (roleClaim !== "Admin" && !(Array.isArray(roleClaim) && roleClaim.includes("Admin"))) {
                    alert("Bu sayfaya erişim yetkiniz yok!");
                    window.location.href = "/Home/Index";
                    return;
                }
            } catch (e) { window.location.href = "/Auth/Login"; return; }

            loadUsers();
            loadGroups();
        });

        function escapeHtml(str) {
            return String(str).replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;");
        }

        // Kullanıcı Listeleme ve İşlemler
        async function loadUsers() {
            try {
                const response = await fetch(`${API_BASE}/Admin/users`, { headers: { "Authorization": `Bearer ${token}` }});
                if (response.ok) {
                    const users = await response.json();
                    let html = "";
                    if(users.length === 0) {
                        html = `<tr><td colspan="4" class="text-center text-muted p-4">Kayıtlı kullanıcı bulunamadı.</td></tr>`;
                    } else {
                        users.forEach(u => html += `
                            <tr>
                                <td><div class="fw-bold">${escapeHtml(u.firstName)} ${escapeHtml(u.lastName)}</div></td>
                                <td class="text-muted">${escapeHtml(u.email)}</td>
                                <td class="text-center"><span class="badge bg-success-subtle text-success rounded-pill px-3">Aktif</span></td>
                                <td class="text-center">
                                    <button class="btn btn-sm btn-outline-warning me-2" onclick="grantAdmin('${u.id}')" title="Admin Yap"><i class="fa-solid fa-shield-halved"></i></button>
                                    <button class="btn btn-sm btn-outline-danger" onclick="deleteUser('${u.id}')" title="Sil"><i class="fa-solid fa-trash"></i></button>
                                </td>
                            </tr>`);
                    }
                    document.getElementById("usersTableBody").innerHTML = html;
                }
            } catch (error) { console.error("User Load Error:", error); }
        }

        async function grantAdmin(userId) {
            if(!confirm("Bu kullanıcıya Admin yetkisi verilsin mi?")) return;
            const res = await fetch(`${API_BASE}/Admin/assign-role/${userId}/Admin`, {
                method: "POST",
                headers: { "Authorization": `Bearer ${token}` }
            });
            if(res.ok) { alert("Rol atandı!"); loadUsers(); }
            else { alert("Hata: Rol atanamadı."); }
        }

        async function deleteUser(id) {
            if(!confirm("Bu kullanıcıyı silmek istediğinize emin misiniz?")) return;
            const res = await fetch(`${API_BASE}/Admin/delete-user/${id}`, {
                method: "DELETE",
                headers: { "Authorization": `Bearer ${token}` }
            });
            if(res.ok) { alert("Kullanıcı silindi."); loadUsers(); }
            else { alert("Hata: Kullanıcı silinemedi."); }
        }

        // Grup Listeleme
        async function loadGroups() {
            try {
                const response = await fetch(`${API_BASE}/Group/list`, { headers: { "Authorization": `Bearer ${token}` }});
                if (response.ok) {
                    const groups = await response.json();
                    let html = "";
                    groups.forEach(g => html += `
                        <li class="list-group-item d-flex justify-content-between align-items-center py-3">
                            <span class="fw-medium">${escapeHtml(g.name)}</span>
                            <span class="badge bg-dark rounded-pill">ID: ${g.id}</span>
                        </li>`);
                    document.getElementById("groupListUI").innerHTML = html || "<li class='list-group-item text-muted text-center p-3'>Henüz grup oluşturulmamış.</li>";
                }
            } catch(error) { console.error("Group Load Error:", error); }
        }

        async function createGroup() {
            const input = document.getElementById("newGroupName");
            const groupName = input.value.trim();
            if(!groupName) return alert("Lütfen bir grup adı girin!");

            try {
                const res = await fetch(`${API_BASE}/Group/create`, {
                    method: "POST",
                    headers: { "Content-Type": "application/json", "Authorization": `Bearer ${token}` },
                    body: JSON.stringify({ name: groupName })
                });
                if(res.ok) {
                    alert("Grup başarıyla oluşturuldu!");
                    input.value = "";
                    loadGroups();
                } else {
                    alert("Grup oluşturulurken hata oluştu.");
                }
            } catch(e) { console.error("Group Create Error:", e); }
        }
    </script>
}